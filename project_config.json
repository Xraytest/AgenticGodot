{
  "name": "agentic-godot",
  "version": "2.0.0",
  "description": "Godot Engine with native C++ MCP module for programmatic control",
  "architecture": "Native C++ Godot Module (modules/agentic_mcp/)",
  "mcp_integration": "Built-in, starts with Godot via --mcp-port CLI flag",
  "homepage": "https://github.com/Xraytest/AgenticGodot",
  "repository": {
    "type": "git",
    "url": "git@github.com:Xraytest/AgenticGodot.git"
  },
  "python_requires": ">=3.8",
  "dependencies": {
    "scons": ">=4.3.0",
    "python": ">=3.8"
  },
  "scripts": {
    "build:windows": "scons -C godot_source platform=windows target=release -j4",
    "build:linux": "scons -C godot_source platform=linuxbsd target=release arch=x86_64 -j$(nproc)",
    "build:linux:headless": "scons -C godot_source platform=linuxbsd target=release arch=x86_64 -j$(nproc)",
    "build:remote:linux": "python scripts/remote_linux_build_v2.py --host 192.168.1.3 --username xray4668 --arch x86_64",
    "mcp:test": "python mcp_client_test.py --host localhost --port 6005 --test"
  },
  "mcp": {
    "native_module": "modules/agentic_mcp/",
    "total_tools": 674,
    "visual_tools": 310,
    "control_tools": 364,
    "protocol": "JSON-RPC 2.0 over TCP",
    "default_port": 6005
  }
}
